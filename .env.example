# ============================================================================
# EverHealthHormIA · Fase 3 · variables de entorno
# ----------------------------------------------------------------------------
# Copia este archivo a .env.local para desarrollo, o configura estas variables
# en Vercel → Settings → Environment Variables para producción.
# Las variables VITE_* se exponen al cliente (son públicas por diseño).
# El resto (sin prefijo VITE_) SOLO viven server-side (funciones /api).
# ============================================================================

# --- Supabase (cliente + server) -------------------------------------------
# Dashboard Supabase → Settings → API
VITE_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJI..."

# --- Claude · Anthropic API (SOLO server, usado por /api/claude) -----------
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# --- Resend · Email transaccional (SOLO server, usado por /api/resend) -----
# resend.com/api-keys
RESEND_API_KEY="re_..."

# Dirección remitente por defecto. Debe estar verificada en Resend.
# En sandbox: 'EverHealthHormIA <noreply@resend.dev>'
# En producción: 'EverHealthHormIA <noreply@tudominio.es>'
EVERHEALTH_FROM="EverHealthHormIA <noreply@resend.dev>"
